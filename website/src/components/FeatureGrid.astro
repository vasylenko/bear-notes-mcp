---
const categories = [
  {
    title: 'Read & Search',
    description: 'Relevance-ranked search across titles, bodies, and tags. Filter by tag, date range, or pinned status.',
  },
  {
    title: 'Create & Edit',
    description: 'Section-aware writes: append at a specific heading, replace a fenced block, or scope edits without rewriting the whole note. Plus attachments and archive.',
  },
  {
    title: 'Tag Management',
    description: 'Library-wide tag operations: rename or delete a tag everywhere, view the full hierarchy with note counts.',
  },
];
---

<section class="py-14 sm:py-20">
  <div class="text-center max-w-2xl mx-auto mb-12">
    <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight">
      12 tools, three jobs
    </h2>
    <p class="mt-4 text-text-secondary leading-relaxed">
      Each tool does one thing well.
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl mx-auto stagger">
    {categories.map((cat) => (
      <div class="surface-card p-6 animate-on-scroll">
        <h3 class="font-bold text-text-primary mb-3">{cat.title}</h3>
        <p class="text-sm text-text-secondary leading-relaxed">{cat.description}</p>
      </div>
    ))}
  </div>
</section>
