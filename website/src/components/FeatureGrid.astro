---
const categories = [
  {
    title: 'Read & Search',
    description: 'Full-text search across notes, tags, and text Bear has indexed from attached images and PDFs. Filter by tags, date ranges, and pinned status.',
  },
  {
    title: 'Create & Edit',
    description: 'Create notes, insert text at the beginning, end, or within a specific section, replace content, attach files, and archive.',
  },
  {
    title: 'Tag Management',
    description: 'Add, rename, and delete tags across your library. View your full tag hierarchy with note counts.',
  },
];
---

<section class="py-14 sm:py-20">
  <div class="text-center max-w-2xl mx-auto mb-12">
    <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight">
      12 tools, three jobs
    </h2>
    <p class="mt-4 text-text-secondary leading-relaxed">
      Each tool does one thing well.
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl mx-auto stagger">
    {categories.map((cat) => (
      <div class="surface-card p-6 animate-on-scroll">
        <h3 class="font-bold text-text-primary mb-3">{cat.title}</h3>
        <p class="text-sm text-text-secondary leading-relaxed">{cat.description}</p>
      </div>
    ))}
  </div>
</section>
