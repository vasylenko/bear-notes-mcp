---
---

<button
  id="theme-toggle"
  type="button"
  class="inline-flex items-center justify-center w-9 h-9 rounded-pill border border-border text-text-muted hover:text-accent hover:border-border-hover transition-colors"
  aria-label="Theme"
  title="Theme"
>
  <svg id="theme-icon-auto" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3" y="4" width="18" height="13" rx="2" />
    <path d="M8 21h8" />
    <path d="M12 17v4" />
  </svg>
  <svg id="theme-icon-light" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>
  <svg id="theme-icon-dark" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn || btn.dataset.bound) return;
    btn.dataset.bound = 'true';

    var labels = {
      auto: 'Theme: auto (follows system). Click for light mode.',
      light: 'Theme: light. Click for dark mode.',
      dark: 'Theme: dark. Click for auto mode.',
    };
    var next = { auto: 'light', light: 'dark', dark: 'auto' };

    function getState() {
      var stored = localStorage.getItem('theme');
      if (stored === 'light' || stored === 'dark') return stored;
      return 'auto';
    }

    function syncIcon(state) {
      ['auto', 'light', 'dark'].forEach(function (s) {
        var icon = document.getElementById('theme-icon-' + s);
        if (icon) icon.classList.toggle('hidden', s !== state);
      });
      btn.setAttribute('aria-label', labels[state]);
      btn.setAttribute('title', labels[state]);
    }

    function apply(state) {
      var meta = document.getElementById('theme-color-meta');
      if (state === 'auto') {
        localStorage.removeItem('theme');
        var systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.classList.toggle('dark', systemDark);
        if (meta) meta.setAttribute('content', systemDark ? '#15140f' : '#f9f8f5');
      } else if (state === 'dark') {
        localStorage.setItem('theme', 'dark');
        document.documentElement.classList.add('dark');
        if (meta) meta.setAttribute('content', '#15140f');
      } else {
        localStorage.setItem('theme', 'light');
        document.documentElement.classList.remove('dark');
        if (meta) meta.setAttribute('content', '#f9f8f5');
      }
      syncIcon(state);
    }

    syncIcon(getState());
    btn.addEventListener('click', function () {
      apply(next[getState()]);
    });
  })();
</script>
