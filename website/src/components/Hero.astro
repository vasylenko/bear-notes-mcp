---
import { site } from '../data/site';
import InstallTabs from './InstallTabs.astro';
---

<section class="pt-12 pb-16 sm:pt-16 sm:pb-24">
  <div class="text-center max-w-4xl mx-auto">
    <!-- Bear mascot -->
    <img src="/bear-mcp-server.webp" alt="bear-notes-mcp mascot" width="160" height="277" class="mx-auto mb-6 animate-on-scroll" />

    <!-- Trust signals — populated client-side via shields.io JSON API -->
    <div id="trust-signals" class="hidden flex items-center justify-center gap-3 mb-8 animate-on-scroll">
      <a href={`${site.links.github}/stargazers`} class="trust-pill" target="_blank" rel="noopener">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-text-muted" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
        </svg>
        <span id="stars-count" class="font-semibold text-text-primary"></span>
      </a>
      <a href={site.links.npm} class="trust-pill" target="_blank" rel="noopener">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-text-muted" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        <span id="downloads-count" class="font-semibold text-text-primary"></span>
      </a>
    </div>
    <div id="trust-signals-spacer" class="mb-5"></div>

    <!-- Headline -->
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1.08] text-text-primary animate-on-scroll" style="animation-delay: 100ms;">
      Bear Notes MCP Server<br />
      <span class="text-highlight">for every AI assistant</span>
    </h1>

    <p class="mt-8 text-lg sm:text-xl text-text-secondary max-w-lg mx-auto leading-relaxed animate-on-scroll" style="animation-delay: 200ms;">
      An MCP server that gives your AI assistant full access to your
      <a href={site.links.bearApp} class="text-text-primary font-semibold hover:text-accent transition-colors" target="_blank" rel="noopener">Bear</a>
      notes. Search with OCR, create, edit, and organize.
    </p>

    <!-- Install tabs -->
    <div class="mt-10 max-w-2xl mx-auto animate-on-scroll" style="animation-delay: 300ms;">
      <InstallTabs group="hero" />
      <p class="mt-4 text-center text-xs text-text-muted">
        <a href="#optional-settings" class="hover:text-text-secondary transition-colors underline decoration-text-muted/30 underline-offset-2">Optional settings</a>
      </p>
    </div>
  </div>
</section>

<script is:inline>
  // Trust signals
  (async () => {
    try {
      const [starsRes, dlRes] = await Promise.all([
        fetch('https://img.shields.io/github/stars/vasylenko/bear-notes-mcp.json'),
        fetch('https://img.shields.io/npm/dm/bear-notes-mcp.json'),
      ]);
      const stars = starsRes.ok ? await starsRes.json() : null;
      const dl = dlRes.ok ? await dlRes.json() : null;
      if (!stars && !dl) return;

      if (stars) document.getElementById('stars-count').textContent = stars.value + ' stars';
      if (dl) document.getElementById('downloads-count').textContent = dl.value;

      document.getElementById('trust-signals').classList.remove('hidden');
      const spacer = document.getElementById('trust-signals-spacer');
      if (spacer) spacer.remove();
    } catch {}
  })();
</script>
