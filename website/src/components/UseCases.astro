---
const useCases = [
  {
    title: 'Knowledge search',
    description: 'You wrote it down somewhere — months ago, maybe under a tag you don’t quite remember. Search ranks by relevance, and rolls hierarchical tags up automatically.',
    prompt: 'Find the spec I wrote about export pipelines, somewhere under #engineering/',
  },
  {
    title: 'Meeting notes',
    description: 'Append decisions to a running ops doc, not a fresh note every time. Section-targeted writes mean today’s notes land under today’s heading without rewriting yesterday’s.',
    prompt: 'Append today\'s decisions to the \'Decisions\' section of my Weekly Ops note',
  },
  {
    title: 'Research & writing',
    description: 'Pull every note under a tag subtree into a synthesis. Restructure a long draft section by section — leaving the rest of the note untouched.',
    prompt: 'Pull every note under #research/llm-evals and outline a survey',
  },
  {
    title: 'Content creation',
    description: 'Draft from what you already wrote. The AI reads your sources, then creates new notes — or extends existing ones at a precise heading — without trampling anything.',
    prompt: 'Find my notes tagged #blog/drafts and draft this week\'s post outline',
  },
];
---

<section class="py-14 sm:py-20">
  <div class="text-center max-w-2xl mx-auto mb-12">
    <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight">
      What you can do
    </h2>
    <p class="mt-4 text-text-secondary leading-relaxed">
      Real things people do with a deep library one prompt away.
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-3xl mx-auto stagger">
    {useCases.map((uc) => (
      <div class="surface-card p-6 animate-on-scroll flex flex-col">
        <h3 class="font-bold text-text-primary mb-2">{uc.title}</h3>
        <p class="text-sm text-text-secondary leading-relaxed mb-4">{uc.description}</p>
        <div class="mt-auto code-surface rounded-lg px-4 py-3 text-sm">
          <span class="text-white/40 select-none">&gt; </span>
          <span class="text-white/80 italic">{uc.prompt}</span>
        </div>
      </div>
    ))}
  </div>
</section>
